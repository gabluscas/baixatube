{
  "manifest_version": 3,
  "name": "BaixaTube",
  "version": "1.0.0",
  "description": "Baixe vídeos e áudios do YouTube com um clique.",
  "permissions": ["activeTab", "downloads", "storage", "notifications"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "http://localhost:9999/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/watch*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "BaixaTube"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
